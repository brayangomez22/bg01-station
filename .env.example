# Web3Forms access key for the comms console (05 · Comunicaciones).
#
# Get one free in seconds at https://web3forms.com — enter the inbox where you
# want transmissions delivered and copy the access key it gives you. No account
# needed. The key is public by design (safe to ship in client code).
#
# Local dev: copy this file to `.env.local` and paste your key below.
# Production (GitHub Pages): add VITE_WEB3FORMS_ACCESS_KEY as a repository
# variable and pass it to `npm run build` in .github/workflows/deploy.yml,
# or hardcode it in src/lib/comms/web3forms.ts (it's public either way).
VITE_WEB3FORMS_ACCESS_KEY=YOUR_ACCESS_KEY_HERE

# Base URL of the BG-01 control API (the Go backend) used by the /control area.
# Public station decks never call it. In production set it to the api.* subdomain
# so the session cookie stays same-site (e.g. https://api.brayangomez.dev).
# Local dev: point it at the running backend.
VITE_API_BASE_URL=http://localhost:8080
